# Shared
NODE_ENV=development
JWT_SECRET=replace-with-secure-shared-jwt-secret
INTERNAL_SIGNATURE_SECRET=replace-with-secure-internal-signature-secret
INTERNAL_SIGNATURE_MAX_SKEW_SECONDS=90

# Gateway
GATEWAY_PORT=3000
SSO_SERVICE_URL=http://localhost:3001
BANK_SERVICE_URL=http://localhost:3002
GATEWAY_RATE_LIMIT_TTL_MS=60000
GATEWAY_RATE_LIMIT_LIMIT=100

# SSO
SSO_PORT=3001
SSO_DATABASE_URL=postgres://postgres:postgres@localhost:5432/sso_db
SSO_BCRYPT_ROUNDS=10
SSO_AUTH_RATE_LIMIT_TTL_MS=60000
SSO_AUTH_RATE_LIMIT_LIMIT=5

# Bank Accounts
BANK_PORT=3002
BANK_DATABASE_URL=postgres://postgres:postgres@localhost:5433/bank_db
MOCKAPI_BASE_URL=https://mockapi.io
BANK_UPSTREAM_MODE=memory
MOCKAPI_TIMEOUT_MS=2000

# Legacy aliases (backward compatibility only; prefer canonical vars above)
# SSO_JWT_SECRET=replace-with-secure-shared-jwt-secret
# BANK_MOCKAPI_BASE_URL=https://mockapi.io
# GATEWAY_SSO_URL=http://localhost:3001
# GATEWAY_BANK_URL=http://localhost:3002
# GATEWAY_INTERNAL_HMAC_SECRET=replace-with-secure-internal-signature-secret
# BANK_INTERNAL_HMAC_SECRET=replace-with-secure-internal-signature-secret
# BANK_INTERNAL_SIGNATURE_MAX_SKEW_SECONDS=90

# Databases
POSTGRES_SSO_PORT=5432
POSTGRES_SSO_DB=sso_db
POSTGRES_SSO_USER=postgres
POSTGRES_SSO_PASSWORD=postgres
POSTGRES_BANK_PORT=5433
POSTGRES_BANK_DB=bank_db
POSTGRES_BANK_USER=postgres
POSTGRES_BANK_PASSWORD=postgres
